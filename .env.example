# Copy this file to .env and fill in your paths.
# Lines starting with # are comments and are ignored.

# ── Dataset location ──────────────────────────────────────────────────────────
# Directory containing fma_small/ and fma_metadata/.
# If you also have fma_medium/ downloaded, put it in the same parent directory.
DATASET_DIR=/path/to/your/data

# Where cleaned CSVs and spectrograms are written.
# Defaults to DATASET_DIR/fma_preprocessed if not set.
# PREPROCESSED_DIR=/path/to/output

# ── Dataset size ──────────────────────────────────────────────────────────────
# Which dataset subsets to clean and generate CSVs for.
#
#   small  → 8,000 tracks, 8 genres
#             Requires: fma_small/ + fma_metadata/
#
#   medium → 25,000 tracks, 16 genres (FMA medium is a superset of small)
#             Requires: fma_small/ + fma_metadata/
#             Medium-only audio (fma_medium/) is optional — tabular features
#             from features.csv cover the medium-only tracks for Random Forest.
#
#   both   → generate CSVs and spectrograms for both subsets independently.
#             Useful when you need a small quick run AND a full medium run.
#
DATASET_SIZE=small

# ── Model preprocessing targets ───────────────────────────────────────────────
# Which spectrogram formats to extract.
#
#   cnn  → 10-second clips  → shape (1, 64, 1001)  written to spectrograms_10/
#   crnn → 20-second clips  → shape (1, 64, 2001)  written to spectrograms_20/
#   both → extract both formats (takes roughly 2× the time and disk space)
#   none → skip spectrogram extraction entirely (CSV cleaning only;
#           useful when you only need Random Forest tabular features)
#
PREPROCESS_FOR=both
