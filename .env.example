# Copy this file to .env and fill in your paths.
# Lines starting with # are comments and are ignored.

# ── Dataset location ──────────────────────────────────────────────────────────
# Directory containing fma_small/ and fma_metadata/.
# If you also have fma_medium/, place it in the same parent directory.
DATASET_DIR=/path/to/your/data

# ── Preprocessed output ───────────────────────────────────────────────────────
# Where cleaned CSVs and spectrograms are written.
# Defaults to DATASET_DIR/fma_preprocessed if not set.
# PREPROCESSED_DIR=/path/to/your/data/fma_preprocessed

# ── Dataset size ──────────────────────────────────────────────────────────────
# Which dataset subset to process: small, medium, or both.
#
#   small  → 8,000 tracks, 8 genres  (requires fma_small/ + fma_metadata/)
#   medium → 25,000 tracks, 16 genres (requires fma_small/ + fma_metadata/)
#   both   → process both subsets; setup also downloads fma_medium/
#
DATASET_SIZE=small

# ── Spectrogram generation ────────────────────────────────────────────────────
# Whether setup.sh should generate spectrogram .npy files after downloading data.
#   0 -> skip spectrogram generation during setup
#   1 -> generate spectrograms for the subset(s) selected by DATASET_SIZE
DOWNLOAD_SPECTROGRAMS=0

# Which spectrogram formats to generate when DOWNLOAD_SPECTROGRAMS=1.
#   cnn  -> 10-second clips for CNN
#   crnn -> 20-second clips for CRNN
#   both -> generate both formats
#   none -> skip spectrogram generation
PREPROCESS_FOR=cnn
