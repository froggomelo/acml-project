# Directory containing fma_small/ and fma_metadata/
# If you also have fma_medium/, place it in the same parent directory.
DATASET_DIR=/home/lily/acml-project

# Where cleaned CSVs and spectrograms are written.
# Defaults to DATASET_DIR/fma_preprocessed if not set.
# PREPROCESSED_DIR=/home/lily/acml-project/fma_preprocessed

# Which dataset subsets to clean and generate CSVs for.
#   small  → 8,000 tracks, 8 genres  (requires fma_small/ + fma_metadata/)
#   medium → 25,000 tracks, 16 genres (requires fma_small/ + fma_metadata/;
#             medium-only audio is not needed — tabular features from features.csv are used)
#   both   → generate CSVs for both subsets independently
DATASET_SIZE=both

# Which model spectrogram formats to extract.
#   cnn  → 10 s clips → shape (1, 64, 1001)  saved to spectrograms_10/
#   crnn → 20 s clips → shape (1, 64, 2001)  saved to spectrograms_20/
#   both → extract both formats
#   none → skip spectrogram extraction (CSV cleaning only, e.g. for Random Forest)
PREPROCESS_FOR=both
